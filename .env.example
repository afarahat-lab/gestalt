# OpenHarness environment configuration
# Copy this file to .env and fill in your values before running docker-compose up

# Server
SERVER_PORT=3000

# PostgreSQL
POSTGRES_USER=openharness
POSTGRES_PASSWORD=change_me_before_production
POSTGRES_DB=openharness

# Redis
# No password by default — add requirepass in redis config for production

# LLM Provider
# For Azure OpenAI:
#   LLM_BASE_URL=https://<your-resource>.openai.azure.com/openai/deployments/<deployment>
#   LLM_API_KEY=<your-azure-api-key>
#   LLM_MODEL=gpt-4o
#
# For Ollama (local):
#   LLM_BASE_URL=http://ollama:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3
#
# For vLLM:
#   LLM_BASE_URL=http://<vllm-host>:8000/v1
#   LLM_API_KEY=<your-api-key>
#   LLM_MODEL=<model-name>

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Auth
JWT_SECRET=change_me_to_a_long_random_string_before_production
