{
  "name": "@gestalt/server",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Fastify server — orchestration, REST API, dashboard serving",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^7.0.0",
    "@gestalt/adapter-postgres": "workspace:*",
    "@gestalt/agents-generate": "workspace:*",
    "@gestalt/agents-quality-gate": "workspace:*",
    "@gestalt/agents-deploy": "workspace:*",
    "@gestalt/agents-maintenance": "workspace:*",
    "@gestalt/agents-planning": "workspace:*",
    "@gestalt/core": "workspace:*",
    "@node-saml/node-saml": "^4.0.5",
    "adm-zip": "^0.5.10",
    "bcrypt": "^5.1.1",
    "fastify": "^4.27.0",
    "jose": "^5.2.0",
    "openid-client": "^5.6.4",
    "simple-git": "^3.23.0",
    "yaml": "^2.4.0"
  },
  "optionalDependencies": {
    "kerberos": "^2.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
