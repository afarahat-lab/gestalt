{
  "name": "@gestalt/adapter-postgres",
  "version": "0.1.0",
  "private": true,
  "description": "PostgreSQL repository adapter (reference implementation)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && mkdir -p dist/migrations && cp src/migrations/*.sql dist/migrations/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gestalt/core": "workspace:*",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
