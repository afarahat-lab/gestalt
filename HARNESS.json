{
  "name": "agentforge-sdlc",
  "version": "0.1.0",
  "tier": "tier1",
  "templateId": "platform-self",
  "repository": "https://github.com/afarahat-lab/agentforge-sdlc",
  "contextFiles": [
    "AGENTS.md",
    "docs/ARCHITECTURE.md",
    "docs/DECISIONS.md",
    "docs/DOMAIN.md",
    "docs/GOLDEN_PRINCIPLES.md"
  ],
  "stack": {
    "language": "typescript",
    "runtime": "node20",
    "packageManager": "pnpm",
    "backend": "fastify",
    "frontend": "react",
    "testFramework": "vitest",
    "linter": "eslint"
  },
  "adapters": {
    "database": {
      "type": "postgres",
      "configKey": "DATABASE_URL"
    },
    "queue": {
      "type": "bullmq",
      "configKey": "REDIS_URL"
    },
    "llm": {
      "type": "openai-compatible",
      "configKey": "LLM_BASE_URL"
    }
  },
  "initializer": {
    "version": "1.0",
    "mode": "intent-first",
    "phases": [
      {
        "phase": 0,
        "name": "llm-bootstrap",
        "description": "Configure LLM provider before anything else",
        "requiresLLM": false
      },
      {
        "phase": 1,
        "name": "intent-capture",
        "description": "Natural language project description, LLM extracts structured answers",
        "requiresLLM": true
      },
      {
        "phase": 2,
        "name": "harness-generation",
        "description": "LLM generates all harness artifacts from structured answers",
        "requiresLLM": true,
        "outputs": [
          "AGENTS.md",
          "ARCHITECTURE.md",
          "DOMAIN.md",
          "DECISIONS.md",
          "GOLDEN_PRINCIPLES.md",
          "HARNESS.json",
          "folder-structure",
          "tsconfig.json",
          "eslint-config",
          "ci-pipeline-config",
          "docker-compose.dev.yml"
        ]
      },
      {
        "phase": 3,
        "name": "harness-validation",
        "description": "Validate coherence and completeness before marking project ready",
        "requiresLLM": false
      }
    ],
    "extractedFields": [
      "projectName",
      "purpose",
      "targetUsers",
      "frontend",
      "backend",
      "database",
      "complianceFrameworks",
      "authMethod",
      "architectureStyle",
      "cicdSystem",
      "multiTenancy",
      "deploymentTarget"
    ]
  },
  "qualityGate": {
    "required": [
      "lint",
      "typecheck",
      "unit-tests",
      "integration-tests",
      "constraint-check",
      "security-scan"
    ],
    "blockingSignals": [
      "GOLDEN_PRINCIPLE_BREACH",
      "CONSTRAINT_VIOLATION"
    ],
    "autoResolvableSignals": [
      "LINT_FAILURE",
      "TEST_FAILURE"
    ],
    "maxRetries": 3
  },
  "maintenance": {
    "driftCheck": {
      "enabled": true,
      "scheduleUtc": "0 2 * * *"
    },
    "alignmentCheck": {
      "enabled": true,
      "scheduleUtc": "0 3 * * *"
    },
    "gcCheck": {
      "enabled": true,
      "scheduleUtc": "0 4 * * 5"
    }
  },
  "updatedAt": "2026-05-01T00:00:00Z"
}
