{
  "name": "agentforge-sdlc",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source self-hosted agent-first platform for the full Software Development Lifecycle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afarahat-lab/agentforge-sdlc.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
