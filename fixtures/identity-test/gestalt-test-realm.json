{
  "realm": "gestalt-test",
  "enabled": true,
  "sslRequired": "none",
  "groups": [
    { "name": "gestalt-admins" },
    { "name": "users" }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@gestalt-test.local",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "alice123", "temporary": false }
      ],
      "groups": ["/gestalt-admins"],
      "realmRoles": ["default-roles-gestalt-test"]
    },
    {
      "username": "bob",
      "email": "bob@gestalt-test.local",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "bob123", "temporary": false }
      ],
      "groups": ["/users"],
      "realmRoles": ["default-roles-gestalt-test"]
    }
  ],
  "clients": [
    {
      "clientId": "gestalt-oidc",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "gestalt-oidc-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/auth/oidc/callback"],
      "webOrigins": ["http://localhost:3000"],
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "http://localhost:3000",
      "name": "gestalt-saml",
      "enabled": true,
      "protocol": "saml",
      "publicClient": true,
      "frontchannelLogout": true,
      "adminUrl": "http://localhost:3000",
      "baseUrl": "http://localhost:3000",
      "redirectUris": ["http://localhost:3000/auth/saml/callback"],
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.authnstatement": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.server.signature": "true",
        "saml.signature.algorithm": "RSA_SHA256",
        "saml_assertion_consumer_url_post": "http://localhost:3000/auth/saml/callback",
        "saml_force_name_id_format": "true",
        "saml_name_id_format": "email",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "config": {
            "user.attribute": "email",
            "friendly.name": "email",
            "attribute.name": "email",
            "attribute.nameformat": "Basic"
          }
        },
        {
          "name": "display-name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "config": {
            "user.attribute": "firstName",
            "friendly.name": "displayName",
            "attribute.name": "displayName",
            "attribute.nameformat": "Basic"
          }
        },
        {
          "name": "groups",
          "protocol": "saml",
          "protocolMapper": "saml-group-membership-mapper",
          "config": {
            "attribute.name": "groups",
            "attribute.nameformat": "Basic",
            "single": "false",
            "full.path": "false"
          }
        }
      ]
    }
  ]
}
