# Never copy these into the build context
node_modules
**/node_modules
.git
.env
.env.local
**/.turbo
**/*.log
npm-debug.log*

# Don't copy docs — not needed for the server build
docs

# templates/ IS copied (ADR-036): the template engine reads
# templates/<id>/ on every init-harness call. The Dockerfile COPYs
# it into the builder + production stages; leaving it out of
# .dockerignore so the build context includes it.

# Don't copy test files into image
**/*.test.ts
**/*.spec.ts

# dist directories are built inside Docker, not copied in
# (intentionally NOT excluded so pnpm install can resolve paths)
